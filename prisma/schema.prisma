generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(cuid())
  name            String?
  email           String?        @unique
  emailVerified   DateTime?
  image           String?
  bannerImage     String?
  bio             String?
  websiteUrl      String?
  twitterUrl      String?
  instagramUrl    String?
  youtubeUrl      String?
  discordUrl      String?
  role            Role           @default(READER)
  stripeAccountId String?        @unique
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  accounts        Account[]
  sessions        Session[]
  series          Series[]
  episodes        Episode[]
  books           Book[]
  stats           UserStats?
  payouts         AuthorPayout[]
  subscriptions   Subscription[]
  adImpressions   AdImpression[]
  readEvents      ReadEvent[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Series {
  id          String    @id @default(cuid())
  title       String
  description String
  genre       String
  tags        String[]
  coverImage  String?
  reads       Int       @default(0)
  followers   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String
  episodes Episode[]
}

model Episode {
  id            String         @id @default(cuid())
  title         String
  episodeNumber Int
  body          String
  teaser        String?
  readTime      Int
  readerCount   Int            @default(0)
  locked        Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  series        Series         @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  seriesId      String
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId      String
  adImpressions AdImpression[]
  readEvents    ReadEvent[]

  @@unique([seriesId, episodeNumber])
}

model UserStats {
  id            String   @id @default(cuid())
  totalReads    Int      @default(0)
  totalEpisodes Int      @default(0)
  totalSeries   Int      @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique
}

model Settings {
  id                 String   @id @default(cuid())
  siteName           String   @default("Dramatized Fiction")
  enableAds          Boolean  @default(false)
  enablePayments     Boolean  @default(false)
  phaseTwoUnlocked   Boolean  @default(false)
  phaseThreeUnlocked Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}

model AuthorPayout {
  id          String       @id @default(cuid())
  amount      Int
  status      PayoutStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  processedAt DateTime?

  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String
}

model Subscription {
  id          String    @id @default(cuid())
  stripeSubId String    @unique
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  canceledAt  DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

model RevenueEvent {
  id        String      @id @default(cuid())
  type      RevenueType
  amount    Int
  userId    String?
  seriesId  String?
  episodeId String?
  createdAt DateTime    @default(now())
}

model AdImpression {
  id        String   @id @default(cuid())
  userId    String?
  episodeId String
  createdAt DateTime @default(now())

  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([userId, episodeId])
}

model ReadEvent {
  id        String   @id @default(cuid())
  userId    String?
  episodeId String
  createdAt DateTime @default(now())

  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([episodeId, createdAt])
}

model Book {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverUrl    String?
  status      String
  createdAt   DateTime @default(now())

  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String
}

model CmsArticle {
  id                 String   @id @default(cuid())
  slug               String   @unique
  title              String
  quickSectionContent String
  deepSectionContent  String
  lastUpdated        DateTime @updatedAt
  createdAt          DateTime @default(now())
}

enum Role {
  READER
  AUTHOR
  ADMIN
  CEO
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

enum RevenueType {
  SUBSCRIPTION
  AD_WATCH
  EPISODE_READ
}
